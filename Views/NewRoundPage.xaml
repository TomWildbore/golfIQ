<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="golfIQ.Views.NewRoundPage"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#0A0A0A">

    <ScrollView>

        <VerticalStackLayout
            Padding="24"
            Spacing="20">

            <Label
                Text="New Round"
                FontSize="32"
                FontAttributes="Bold"
                TextColor="White"/>

            <Label
                Text="Record your latest round"
                TextColor="#A0A0A0"/>

            <Frame
                BackgroundColor="#151515"
                CornerRadius="16"
                Padding="16"
                HasShadow="False">

                <VerticalStackLayout Spacing="15">

                    <Entry
                        x:Name="CourseEntry"
                        Placeholder="Course Name"
                        TextColor="White"
                        PlaceholderColor="#808080"/>

                    <DatePicker
                        x:Name="RoundDatePicker"
                        TextColor="White"/>

                    <Entry
                        x:Name="ScoreEntry"
                        Placeholder="Score"
                        Keyboard="Numeric"
                        TextColor="White"
                        PlaceholderColor="#808080"/>

                </VerticalStackLayout>

            </Frame>

            <Button
                Text="Save Round"
                BackgroundColor="#8BCF4A"
                TextColor="Black"
                FontAttributes="Bold"
                HeightRequest="55"
                CornerRadius="16"
                Clicked="OnSaveRoundClicked"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>
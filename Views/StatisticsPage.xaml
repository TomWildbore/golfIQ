<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="golfIQ.Views.StatisticsPage"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#0A0A0A">

    <ScrollView>

        <VerticalStackLayout
            Padding="24"
            Spacing="20">

            <!-- Header -->
            <Label
                Text="Statistics"
                FontSize="32"
                FontAttributes="Bold"
                TextColor="White" />

            <Label
                Text="Track your performance over time"
                FontSize="15"
                TextColor="#A0A0A0" />

            <!-- Main Stats -->
            <Grid
                ColumnDefinitions="*,*"
                ColumnSpacing="12">

                <Frame
                    BackgroundColor="#151515"
                    CornerRadius="18"
                    Padding="16"
                    HasShadow="False">

                    <VerticalStackLayout>
                        <Label
                            Text="Average Score"
                            TextColor="#A0A0A0" />

                        <Label
                            Text="84.3"
                            FontSize="30"
                            FontAttributes="Bold"
                            TextColor="White" />
                    </VerticalStackLayout>

                </Frame>

                <Frame
                    Grid.Column="1"
                    BackgroundColor="#151515"
                    CornerRadius="18"
                    Padding="16"
                    HasShadow="False">

                    <VerticalStackLayout>
                        <Label
                            Text="Best Score"
                            TextColor="#A0A0A0" />

                        <Label
                            Text="78"
                            FontSize="30"
                            FontAttributes="Bold"
                            TextColor="#8BCF4A" />
                    </VerticalStackLayout>

                </Frame>

            </Grid>

            <!-- Secondary Stats -->
            <Grid
                ColumnDefinitions="*,*"
                ColumnSpacing="12">

                <Frame
                    BackgroundColor="#151515"
                    CornerRadius="18"
                    Padding="16"
                    HasShadow="False">

                    <VerticalStackLayout>
                        <Label
                            Text="Worst Score"
                            TextColor="#A0A0A0" />

                        <Label
                            Text="96"
                            FontSize="30"
                            FontAttributes="Bold"
                            TextColor="White" />
                    </VerticalStackLayout>

                </Frame>

                <Frame
                    Grid.Column="1"
                    BackgroundColor="#151515"
                    CornerRadius="18"
                    Padding="16"
                    HasShadow="False">

                    <VerticalStackLayout>
                        <Label
                            Text="Rounds Played"
                            TextColor="#A0A0A0" />

                        <Label
                            Text="27"
                            FontSize="30"
                            FontAttributes="Bold"
                            TextColor="White" />
                    </VerticalStackLayout>

                </Frame>

            </Grid>

            <!-- Personal Best -->
            <Frame
                BackgroundColor="#151515"
                CornerRadius="18"
                Padding="20"
                HasShadow="False">

                <VerticalStackLayout
                    Spacing="8">

                    <Label
                        Text="Personal Best"
                        FontSize="14"
                        FontAttributes="Bold"
                        TextColor="#8BCF4A" />

                    <Label
                        Text="78"
                        FontSize="42"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <Label
                        Text="Achieved at Royal Liverpool"
                        FontSize="14"
                        TextColor="#A0A0A0" />

                </VerticalStackLayout>

            </Frame>

            <!-- Recent Performance -->
            <Label
                Text="Recent Performance"
                FontSize="22"
                FontAttributes="Bold"
                TextColor="White" />

            <Frame
                BackgroundColor="#151515"
                CornerRadius="16"
                Padding="16"
                HasShadow="False">

                <Grid
                    ColumnDefinitions="*,Auto"
                    RowDefinitions="Auto,Auto">

                    <Label
                        Text="Last 5 Round Average"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <Label
                        Grid.Column="1"
                        Text="83.2"
                        FontSize="24"
                        FontAttributes="Bold"
                        TextColor="#8BCF4A" />

                    <Label
                        Grid.Row="1"
                        Text="Improving by 2.1 strokes"
                        FontSize="13"
                        TextColor="#A0A0A0" />

                </Grid>

            </Frame>

            <!-- Lowest Rounds -->
            <Label
                Text="Top Scores"
                FontSize="22"
                FontAttributes="Bold"
                TextColor="White" />

            <Frame
                BackgroundColor="#151515"
                CornerRadius="16"
                Padding="16"
                HasShadow="False">

                <VerticalStackLayout Spacing="12">

                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Text="1 " TextColor="#8BCF4A" FontAttributes="Bold"/>
                        <Label Grid.Column="1" Text="Royal Liverpool" TextColor="White"/>
                        <Label Grid.Column="2" Text="78" TextColor="#8BCF4A" FontAttributes="Bold"/>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Text="2 " TextColor="#8BCF4A" FontAttributes="Bold"/>
                        <Label Grid.Column="1" Text="St Andrews" TextColor="White"/>
                        <Label Grid.Column="2" Text="82" TextColor="#8BCF4A" FontAttributes="Bold"/>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Text="3 " TextColor="#8BCF4A" FontAttributes="Bold"/>
                        <Label Grid.Column="1" Text="Pebble Beach" TextColor="White"/>
                        <Label Grid.Column="2" Text="83" TextColor="#8BCF4A" FontAttributes="Bold"/>
                    </Grid>

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>